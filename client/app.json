{
  "expo": {
    "name": "SkyNest Weather",
    "slug": "skynest-weather",
    "scheme": "weatherapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon-liquid.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-brand.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E1B4B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mayank.weatherapp"
    },
    "android": {
      "package": "com.mayank.weatherapp",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#5B3FD3",
        "foregroundImage": "./assets/midrain-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "androidStatusBar": {
      "translucent": true,
      "barStyle": "light-content"
    },
    "androidNavigationBar": {
      "visible": "sticky-immersive",
      "backgroundColor": "#00000000"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "20cc4029-d3c6-4548-a61e-4e9b81f765df"
      }
    },
    "owner": "mayank8159"
  }
}
